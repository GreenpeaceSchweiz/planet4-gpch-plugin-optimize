	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build",
		"format": "wp-scripts format",
		"format:php": "vendor/bin/phpcbf --standard=WordPress --extensions=php ./classes/ planet4-gpch-plugin-optimize.php",
